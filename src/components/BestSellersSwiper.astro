---
---

<section class="best-sellers">
  <h2>check out our best sellers</h2>
  <p class="subtitle">25% Off Flavors and Accessories!</p>

  <div class="swiper-container" id="best-seller-swiper">
    <button class="swiper-btn prev" aria-label="Previous">&lt;</button>
    <div class="swiper-wrapper" id="swiper-track">
      <!-- Generated by JS -->
    </div>
    <button class="swiper-btn next" aria-label="Next">&gt;</button>
  </div>
</section>

<style>
  .best-sellers {
    text-align: center;
    padding: 3rem 1rem;
    font-family: sans-serif;
  }
  .best-sellers h2 {
    font-size: 1.8rem;
    color: #002D5A;
    margin-bottom: 0.5rem;
  }
  .subtitle {
    font-size: 1rem;
    color: #002D5A;
    margin-bottom: 2rem;
  }
  .swiper-container {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
  }
  .swiper-btn {
    background: transparent;
    border: none;
    font-size: 2rem;
    cursor: pointer;
    color: #333;
    padding: 0 1rem;
    z-index: 10;
  }
  .swiper-wrapper {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    gap: 1.5rem;
    padding: 1rem;
    scrollbar-width: none; /* Firefox */
  }
  .swiper-wrapper::-webkit-scrollbar {
    display: none; /* Safari and Chrome */
  }
  :global(.product-card) {
    background: white;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    border-radius: 12px;
    min-width: 200px;
    flex: 0 0 auto;
    scroll-snap-align: start;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }
  :global(.product-card img) {
    height: 180px;
    object-fit: contain;
    margin-bottom: 1rem;
  }
  :global(.product-title) {
    font-size: 0.9rem;
    color: #002D5A;
    font-weight: 600;
    margin-bottom: 0.5rem;
    height: 2.5em;
    overflow: hidden;
  }
  :global(.price-container) {
    margin-bottom: 1rem;
  }
  :global(.original-price) {
    text-decoration: line-through;
    color: #999;
    margin-right: 0.5rem;
    font-size: 0.8rem;
  }
  :global(.current-price) {
    color: #002D5A;
    font-weight: bold;
    font-size: 1.1rem;
  }
  :global(.add-to-cart-btn) {
    background: transparent;
    border: 1px solid #002D5A;
    border-radius: 20px;
    padding: 0.5rem 1.5rem;
    color: #002D5A;
    font-weight: bold;
    cursor: pointer;
    transition: all 0.2s;
    width: 100%;
  }
  :global(.add-to-cart-btn:hover) {
    background: #002D5A;
    color: white;
  }
</style>

<script>
  async function loadProducts() {
    try {
      // Pour des raisons de performance (CSR rapide pour le swiper), on call l'API locale
      const res = await fetch('/api/best-sellers.json');
      const products = await res.json();
      
      const track = document.getElementById('swiper-track');
      if (!track) return;

      track.innerHTML = products.map((p: any) => `
        <div class="product-card">
          <img src="${p.image}" alt="${p.title}" loading="lazy" />
          <h3 class="product-title">${p.title}</h3>
          <div class="price-container">
            <span class="original-price">${p.originalPrice}</span>
            <span class="current-price">${p.currentPrice}</span>
          </div>
          <button class="add-to-cart-btn">add to cart</button>
        </div>
      `).join('');
    } catch (e) {
      console.error('Failed to load products', e);
    }
  }

  // Setup swiper buttons
  document.addEventListener('DOMContentLoaded', () => {
    loadProducts();

    const track = document.getElementById('swiper-track');
    const prev = document.querySelector('.swiper-btn.prev');
    const next = document.querySelector('.swiper-btn.next');

    const scrollAmount = 250;

    prev?.addEventListener('click', () => {
      track?.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });

    next?.addEventListener('click', () => {
      track?.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });
  });
</script>